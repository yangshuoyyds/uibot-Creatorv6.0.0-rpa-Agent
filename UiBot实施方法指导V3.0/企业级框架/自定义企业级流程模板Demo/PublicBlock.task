Rem 1、初始化全局变量（只有Worker的情况下）
Rem 功能：初始化全局变量（只有Worker的情况下，项目参数放在本地配置文件Config.ini或Config.xlsx中）
Rem 入参：无
Rem 出参：无

Function InitArgByLocal()
	TracePrint "——————进入InitArgByLocal函数——————"
	
	Dim sRet = ""
	g_iRetryNum = g_iRetryNum + 1
	TracePrint g_iRetryNum
	
	g_dictGlobal = {}
	Rem 流程异常记录
	g_dictGlobal["isEx"] = False
	sRet = INI.Read(@res"Config.ini", "参数值", "maxRetryNum", "3")
	sRet = CInt(sRet)
	TracePrint sRet
	g_dictGlobal["maxRetryNum"] = sRet
	
	g_dictGlobal["jdAddr"] = INI.Read(@res"Config.ini", "地址", "京东地址", "https://www.jd.com/")
	TracePrint g_dictGlobal["jdAddr"]
	
	g_dictGlobal["ddAddr"] = INI.Read(@res"Config.ini", "地址", "当当地址", "http://book.dangdang.com/")
	TracePrint g_dictGlobal["ddAddr"]
	
	g_dictGlobal["emailAddr"] = INI.Read(@res"Config.ini", "地址", "邮件地址", "uibot_js@laiye.com")
	TracePrint g_dictGlobal["emailAddr"]
	
	g_dictGlobal["bookName"] = INI.Read(@res"Config.ini", "查询", "书籍名", "rpa uibot")
	TracePrint g_dictGlobal["bookName"]
	
	TracePrint "——————退出InitArgByLocal函数——————"
End Function

